---
// Utilise @ pour pointer directement vers le dossier src
import Layout from '@/layouts/Layout.astro'; 
import Section from '@/components/ui/section.astro';
---

<Layout title="Merci | Nexus DevOps">
  <div class="flex flex-col items-center justify-center text-center min-h-[60vh] px-4">
    <h1 class="text-4xl font-bold text-primary mb-4">Message forgé avec succès !</h1>
    <p class="text-xl text-muted-foreground mb-8">
      Merci de ton message. Je l'ai bien reçu dans la console Nexus et je te répondrai dès que possible.
    </p>
    <a href="/" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
      Retourner à l'accueil
    </a>
  </div>
</Layout>